rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net: Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Data Validation Blueprints ---

    function isValidUser(data) {
      // Identity Protection
      return data.keys().hasAll(['uid', 'email', 'createdAt'])
          && data.keys().size() <= 6
          && data.uid == request.auth.uid
          && data.email is string && data.email.size() <= 256
          && (data.get('displayName', '') is string && data.get('displayName', '').size() <= 100)
          && (data.get('photoURL', '') is string && data.get('photoURL', '').size() <= 512)
          && data.createdAt == request.time;
    }

    function isValidFlashcard(card) {
      return card is map
          && card.front is string && card.front.size() <= 500
          && card.back is string && card.back.size() <= 1000;
    }

    function isValidQuizQuestion(q) {
      return q is map
          && q.question is string && q.question.size() <= 600
          && q.options is list && q.options.size() >= 2 && q.options.size() <= 5
          && (q.options.size() > 0 && q.options[0] is string && q.options[0].size() <= 600)
          && q.correctAnswer is string && q.correctAnswer.size() <= 600
          && (q.get('explanation', '') is string && q.get('explanation', '').size() <= 2000);
    }

    function isValidStudyGuide(data) {
      // Schema Enforcement
      return data.keys().hasAll(['userId', 'title', 'flashcards', 'quiz', 'createdAt'])
          && data.keys().size() <= 10
          && data.userId == request.auth.uid
          && data.title is string && data.title.size() <= 300
          && data.flashcards is list && data.flashcards.size() <= 40
          // Value Poisoning Guard
          && (data.flashcards.size() == 0 || isValidFlashcard(data.flashcards[0]))
          && data.quiz is list && data.quiz.size() <= 20
          && (data.quiz.size() == 0 || isValidQuizQuestion(data.quiz[0]))
          && (data.get('folderId', '') is string && data.get('folderId', '').size() <= 128)
          && (data.get('imageUrl', '') is string && data.get('imageUrl', '').size() <= 1500000) // Support small base64
          && (data.get('isPublic', false) is bool)
          && data.createdAt == request.time;
    }

    function isValidFolder(data) {
      return data.keys().hasAll(['name', 'createdAt'])
          && data.keys().size() <= 4
          && data.name is string && data.name.size() <= 100
          && (data.get('color', '') is string && data.get('color', '').size() <= 7)
          && data.createdAt == request.time;
    }

    // --- Collection Routes ---

    // 1. User Profiles
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming()) && isValidId(userId);
      allow update: if isOwner(userId) 
          && incoming().uid == existing().uid
          && incoming().createdAt == existing().createdAt
          && (
            (incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']))
          );

      // 1.5 Folders
      match /folders/{folderId} {
        allow read, write: if isOwner(userId);
        allow create: if isOwner(userId) && isValidFolder(incoming());
      }

      // 2. Study Guides
      match /studyGuides/{guideId} {
        // Secure List Query: Rule itself enforces user filtering
        allow list: if isOwner(userId) && resource.data.userId == userId;
        allow get: if isOwner(userId) || (resource.data.get('isPublic', false) == true);
        
        allow create: if isOwner(userId) 
            && isValidStudyGuide(incoming()) 
            && isValidId(guideId);
            
        allow delete: if isOwner(userId);
        
        allow update: if isOwner(userId)
            && incoming().userId == userId
            && incoming().createdAt == existing().createdAt
            && (
              // Action: Rename, Reorganize, or Share
              (incoming().diff(existing()).affectedKeys().hasOnly(['title', 'folderId', 'isPublic'])) 
            );
      }
    }
  }
}
